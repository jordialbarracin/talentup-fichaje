# ============================================================
# TalentUP Fichaje — Variables de Entorno
# Copia este archivo como .env y rellena los valores
# ============================================================

# Entorno: development | staging | production
APP_ENV=development

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
#   DEBUG: activa logs de desarrollo; INFO por defecto en producción.
LOG_LEVEL=INFO

# Formato de logs: json | auto (por defecto usa json en prod/staging)
# LOG_FORMAT=json

# URL pública del backend (usada por CORS interno/documentación)
BACKEND_URL=http://localhost:8000

# Puerto del servidor
PORT=8000

# ── Base de datos ────────────────────────────────────────────
# URL de la base de datos.
# SQLite local:     sqlite+aiosqlite:///./talentup_fichaje.db
# PostgreSQL local: postgresql+asyncpg://talentup:secret@localhost:5432/talentup_fichaje
# PostgreSQL prod:  postgresql+asyncpg://user:pass@host:5432/talentup_fichaje
DATABASE_URL=sqlite+aiosqlite:///./talentup_fichaje.db

# ── Redis ────────────────────────────────────────────────────
# URL de Redis para colas, caché, rate-limiting distribuido y health checks.
REDIS_URL=redis://localhost:6379/0

# ── Seguridad / JWT ──────────────────────────────────────────
# Secreto JWT — genera uno seguro con: openssl rand -hex 32
JWT_SECRET=generar-uno-seguro

# Duración del token JWT en minutos (por defecto 8 horas)
JWT_EXPIRE_MINUTES=480

# Sal para el hash rápido de PIN (SHA-256). Debe ser distinto en cada tenant/producción.
# Genera uno seguro con: openssl rand -hex 16
PIN_HASH_SALT=generar-uno-seguro

# ── CORS / Frontend ──────────────────────────────────────────
# Orígenes permitidos por CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# URL pública del frontend (usada por Stripe / emails / webhooks)
FRONTEND_URL=http://localhost:3000

# ── Stripe / Pagos ───────────────────────────────────────────
# Clave secreta de Stripe (test/live sk_...)
STRIPE_SECRET_KEY=sk_test_...o_omitir_en_local

# Secreto del webhook endpoint de Stripe (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_...o_omitir_en_local

# IDs de precios de Stripe
STRIPE_PRICE_BASIC=price_basic_dev
STRIPE_PRICE_PRO=price_pro_dev

# ── Docker Compose local (se usan si APP_ENV != production) ──
POSTGRES_USER=talentup
POSTGRES_PASSWORD=talentup_secret
POSTGRES_DB=talentup_fichaje
