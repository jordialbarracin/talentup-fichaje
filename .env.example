# ============================================================
# TalentUP Fichaje — Variables de Entorno
# Copia este archivo como .env y rellena los valores
# ============================================================

# Entorno: development | staging | production
APP_ENV=development

# Secreto JWT — genera uno seguro con: openssl rand -hex 32
JWT_SECRET=generar-uno-seguro

# Duración del token JWT en minutos (por defecto 8 horas)
JWT_EXPIRE_MINUTES=480

# URL de la base de datos (PostgreSQL en producción, SQLite por defecto en local)
# Ejemplo local con Docker: postgresql+asyncpg://talentup:secret@localhost:5432/talentup_fichaje
DATABASE_URL=postgresql://user:***@localhost:5432/talentup_fichaje

# Orígenes permitidos por CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Sal para el hash rápido de PIN (SHA-256). Debe ser distinto en cada tenant/producción.
# Genera uno seguro con: openssl rand -hex 16
PIN_HASH_SALT=generar-uno-seguro

# URL de Redis para colas, caché y rate-limiting distribuido
REDIS_URL=redis://localhost:6379/0

# URL pública del frontend (usada por Stripe / emails / webhooks)
FRONTEND_URL=http://localhost:3000

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Puerto del servidor
PORT=8000

# --- Docker Compose local (se usan si APP_ENV != production) ---
POSTGRES_USER=talentup
POSTGRES_PASSWORD=talentup_secret
POSTGRES_DB=talentup_fichaje
